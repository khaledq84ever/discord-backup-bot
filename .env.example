# Discord bot token (Developer Portal → Bot → Reset Token).
# ⚠ Enable the SERVER MEMBERS INTENT and MESSAGE CONTENT INTENT
# on the Bot page before running — both are needed to back up
# member lists and message text respectively.
DISCORD_TOKEN=

# Bot application / client ID (Developer Portal → General Information).
APPLICATION_ID=

# Optional dev guild for instant slash-command sync.
DEV_GUILD_ID=

# Optional caps. 0 = unlimited.
MAX_MESSAGES_PER_CHANNEL=0
MAX_ATTACHMENT_MB=50

# Auto-backup every N hours (0 = off, run manually only).
AUTO_BACKUP_HOURS=0
